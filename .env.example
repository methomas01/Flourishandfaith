# Flourish & Faith — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Supabase (required for real auth + cloud sync) ──────────────────────────
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic API (required for Sage AI — server-side only) ─────────────────
# Get this from console.anthropic.com
# Add this in Vercel: Project → Settings → Environment Variables
# DO NOT prefix with VITE_ — it must stay server-side.
ANTHROPIC_API_KEY=sk-ant-api03-...
